    "test:coverage": "vp test --coverage",
    "prepare": "vp config"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.8",
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.27.5",
    "@vitest/coverage-v8": "^4.0.0",
    "vite": "catalog:",
    "vitest": "catalog:",
    "vite-plus": "catalog:"
  },
  "pnpm": {
    "overrides": {
      "@types/node": "^20.0.0"
    }
  }
